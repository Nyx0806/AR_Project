MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: -727525145, guid: 24b5c68231d8d2541bc6d98f4cc2eb93, type: 3}
  m_Name: Move
  m_EditorClassIdentifier: TrueInputSystem.Runtime.dll::TrueInputSystem.TISInputProfileConfig
  profileName: Move
  description: 
  enablePC: 0
  enableGamepad: 0
  enableMobile: 1
  actionMaps:
  - mapName: Movement
    enabledByDefault: 1
    actions:
    - actionName: Move
      actionType: 1
      bindingPC: <Keyboard>/wasd
      bindingPCModifier: 
      bindingGamepad: <Gamepad>/leftStick
      bindingGamepadModifier: 
      bindingMobile: TISVirtualJoystick
      readMode: 1
      isSinglePress: 0
      _readModeMigrated: 1
      overrideDeadzone: 0
  - mapName: Camera
    enabledByDefault: 0
    actions:
    - actionName: Look
      actionType: 1
      bindingPC: <Mouse>/delta
      bindingPCModifier: 
      bindingGamepad: <Gamepad>/rightStick
      bindingGamepadModifier: 
      bindingMobile: CameraZone
      readMode: 1
      isSinglePress: 0
      _readModeMigrated: 1
      overrideDeadzone: 0
  - mapName: Skill
    enabledByDefault: 1
    actions:
    - actionName: Up
      actionType: 0
      bindingPC: <Mouse>/leftButton
      bindingPCModifier: 
      bindingGamepad: <Gamepad>/buttonWest
      bindingGamepadModifier: 
      bindingMobile: Button_2
      readMode: 1
      isSinglePress: 0
      _readModeMigrated: 1
      overrideDeadzone: 0
    - actionName: Down
      actionType: 0
      bindingPC: <Keyboard>/q
      bindingPCModifier: 
      bindingGamepad: <Gamepad>/leftShoulder
      bindingGamepadModifier: 
      bindingMobile: Button_3
      readMode: 1
      isSinglePress: 0
      _readModeMigrated: 1
      overrideDeadzone: 0
  mobileSettings:
    joystickRadius: 100
    joystickDeadzone: 0.08
    dynamicJoystick: 1
    idleOpacity: 0.4
